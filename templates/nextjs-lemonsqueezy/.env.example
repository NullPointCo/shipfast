# Lemon Squeezy (create keys at https://app.lemonsqueezy.com/settings/api)
LEMONSQUEEZY_API_KEY=your_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Variant IDs from your Lemon Squeezy products (Products > ... > Variants)
NEXT_PUBLIC_LS_STARTER_VARIANT_ID=your_starter_variant_id
NEXT_PUBLIC_LS_PRO_VARIANT_ID=your_pro_variant_id

# Optional display name on the pricing page
NEXT_PUBLIC_SITE_NAME={{PROJECT_NAME}}

# Public base URL (used for redirect URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
